<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/public/stylesheet/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>

<body>
        <div class="main w-full min-h-screen bg-zinc-900 p-10 text-white">
        <div class="nav mb-10 ">
            <a href="/read" class="text-blue-500">Go to Read</a>
        </div>
        <h1 class="text-3xl tracking-tighter mb-3">Update User</h1>
        <form action="/update/<%= user._id %>" method="post">
            <input type="text" class="border-2 rounded-md outline-none px-5 py-2 border-zinc-800" name="name" placeholder="Name" value="<%= user.name %>">
            <input type="text" class="border-2 rounded-md outline-none px-5 py-2 border-zinc-800" name="email" placeholder="Email" value="<%= user.email %>">
            <input type="text" class="border-2 rounded-md outline-none px-5 py-2 border-zinc-800" name="image" placeholder="Image url" value="<%= user.image %>">
            <input type="submit" class="rounded-lg mt-3 px-5 py-2 bg-yellow-500 text-black" value="Update User">
        </form>
    </div>
</body>

</html>